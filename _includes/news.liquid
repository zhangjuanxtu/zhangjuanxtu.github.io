<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          {% assign item_title = item.title | default: '' | strip %}
          {% assign item_content = item.content | remove: '<p>' | remove: '</p>' | strip %}
          {% if item_title == '' and item_content == '' %}
            {% continue %}
          {% endif %}
          <tr>
            <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td>
              {% if item.inline %}
                {% if item.title and item.url %}
                  <strong><a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a></strong>
                  {% if item_content != '' %}
                    : {{ item_content | emojify }}
                  {% endif %}
                {% elsif item.title %}
                  <strong>{{ item.title }}</strong>
                  {% if item_content != '' %}
                    : {{ item_content | emojify }}
                  {% endif %}
                {% else %}
                  {% if item_content != '' %}
                    {{ item_content | emojify }}
                  {% else %}
                    <em>Update details coming soon.</em>
                  {% endif %}
                {% endif %}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
